AUTH_SERVICE_API_KEY=your-auth-api-key-here

# --- Credits Service ---
# Servicio de créditos — AÚN NO DISPONIBLE
# Descomentar cuando el servicio exista
# CREDITS_SERVICE_URL=https://credits.konfio.mx/api/v1
